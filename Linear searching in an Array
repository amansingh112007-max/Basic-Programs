#include <stdio.h>

int main() {
    int arr[50];        // Declaring array
    int n, i;           // n = number of elements
    int key;            // Element to be searched in Array
    int found = 0;      // Flag variable. 

    // Step 1: Read number of elements.
    printf("Enter number of elements: ");
    scanf("%d", &n);

    // Step 2: Read array elements.
    printf("Enter array elements:\n");
    for (i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    // Step 3: Read the element to search.
    printf("Enter the element to search: ");
    scanf("%d", &key);

    // Step 4: Perform Linear Search.
    for (i = 0; i < n; i++) {
        if (arr[i] == key) {
            printf("Element found at position %d\n", i + 1);
            found = 1;      // Element found
            break;          // Stop searching
        }
    }
    // Step 5: If element not found.
    if (found == 0) {
        printf("Element not found in the array\n");
    }
    return 0;
}


